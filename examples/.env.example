# Copy to .env and fill in values:
#   cp examples/.env.example examples/.env
# Or create .env in project root; the script checks both.
#
# Use the SAME wallet for TS and Py: set PRIVATE_KEY (or AGENT_PRIVATE_KEY) to the same
# value in agent0-ts/examples/.env and agent0-py/examples/.env so both demos use one wallet.

# Required for x402/A2A demo (PRIVATE_KEY or AGENT_PRIVATE_KEY — same as TS demo)
PRIVATE_KEY=0x...
# Primary SDK RPC (default CHAIN_ID=84532 Base Sepolia in x402_a2a_demo.py — keep this on testnet)
RPC_URL=https://base-sepolia.drpc.org

# MCP demo (examples/mcp_demo.py) uses chain 8453 + agent 8453:28350 — needs Base MAINNET, not Sepolia.
# If RPC_URL points to Base Sepolia, set this so loadAgent() hits the right chain:
DELX_RPC_URL=https://mainnet.base.org

# Chain (default 84532 = Base Sepolia, same as TS demo)
# CHAIN_ID=84532

# Flow 2/3: agent IDs (defaults match TS demo). loadAgent() needs IPFS configured to fetch registration.
# AGENT_ID_PURE_A2A=84532:1298
# AGENT_ID_A2A_X402=84532:1301

# Optional: override x402 flow 1 URL (default: Twitter x402 API that returns 402; set to https://httpbin.org/get for no 402)
# X402_DEMO_URL=

# Optional: multichain (mainnet RPC for payments on other chains)
# BASE_MAINNET_RPC_URL=https://base.drpc.org
# OVERRIDE_RPC_URLS={"1":"https://eth.llamarpc.com","8453":"https://mainnet.base.org"}
